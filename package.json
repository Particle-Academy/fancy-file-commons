{
  "name": "@particle-academy/fancy-file-commons",
  "version": "0.1.1",
  "description": "Shared pure core for the Fancy file-focused packages — editors, viewers, writers, and diff surfaces. Structured diff engine + model, git unified-diff parser, merge resolution, per-line gutter annotations, path helpers, and filename→language resolution. Zero dependencies, no React.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-file-commons.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-file-commons#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-file-commons/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "file",
    "diff",
    "lcs",
    "unified-diff",
    "gutter",
    "annotations",
    "language-detection",
    "path",
    "fancy-ui",
    "particle-academy"
  ],
  "license": "MIT",
  "sideEffects": false,
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
